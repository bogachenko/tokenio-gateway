# Copy to .env.docker for local docker-compose runs.
# Values below are local-development defaults. Do not reuse them in production.

TOKENIO_POSTGRES_DB=tokenio
TOKENIO_POSTGRES_USER=tokenio
TOKENIO_POSTGRES_PASSWORD=tokenio_dev_password
TOKENIO_POSTGRES_PORT=5432
TOKENIO_HTTP_PORT=8080

TOKENIO_DATABASE_DSN=postgres://tokenio:tokenio_dev_password@postgres:5432/tokenio?sslmode=disable
DATABASE_URL=postgres://tokenio:tokenio_dev_password@postgres:5432/tokenio?sslmode=disable

TOKENIO_HTTP_ADDR=:8080
HTTP_ADDR=:8080

TOKENIO_API_KEY_HASH_SECRET=dev-tokenio-api-key-hash-secret-change-me
TOKENIO_ADMIN_TOKEN=dev-admin-token-change-me
TOKENIO_SERVICE_TOKEN=dev-provisioning-service-token-change-me
TOKENIO_BILLING_JWT_SECRET=dev-billing-jwt-secret-change-me
